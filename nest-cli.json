{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/smart-order-system/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/smart-order-system/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/smart-order-system",
  "projects": {
    "auth": {
      "type": "application",
      "root": "apps/auth",
      "entryFile": "main",
      "sourceRoot": "apps/auth/src",
      "compilerOptions": {
        "tsConfigPath": "apps/auth/tsconfig.app.json"
      }
    },
    "smart-order-system": {
      "type": "application",
      "root": "apps/smart-order-system",
      "entryFile": "main",
      "sourceRoot": "apps/smart-order-system/src",
      "compilerOptions": {
        "tsConfigPath": "apps/smart-order-system/tsconfig.app.json"
      }
    }
  }
}